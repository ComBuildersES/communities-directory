{
  "name": "Bookworm",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "runArgs": ["-p", "5173:5173"],
  "mounts": [
    "source=/home/home-server/.ssh,target=/home/vscode/.ssh,type=bind,readonly"
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite dev server"
    }
  }
}